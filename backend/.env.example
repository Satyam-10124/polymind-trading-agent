# ── Wallet (Polygon) ──────────────────────────────────────────
WALLET_ADDRESS=0x62A8cAbc0E77BCE7f1B2D1030f1c04511a649D43
PRIVATE_KEY=0xadef1ba865db37d577c295ad876fd0d7886d560475898fe7eb6c819c6ebc03e2

# ── Virtuals / Claude ─────────────────────────────────────────
VIRTUALS_API_KEY=acp-26dcd794feb8cbace143
VIRTUALS_BASE_URL=https://compute.virtuals.io/v1

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=FILL_THIS_IN
TELEGRAM_CHAT_ID=FILL_THIS_IN

# ── Dashboard API security ────────────────────────────────────
# Bearer token for the dashboard API. Unset = auth DISABLED (local dev only) —
# set it for any non-local deployment. Must match the dashboard's VITE_API_TOKEN.
API_TOKEN=
# Comma-separated CORS allow-list for the API (no spaces required).
DASHBOARD_ORIGINS=http://localhost:5173
# SQLite location. Leave unset for local dev (defaults to backend/../polymind.db).
# In production point at a persistent disk, e.g. DB_PATH=/data/polymind.db
# DB_PATH=/data/polymind.db

# ── Trading Config ────────────────────────────────────────────
PAPER_MODE=true
BANKROLL=50.0
MAX_BET_PCT=0.10
KELLY_FRACTION=0.5
TAKE_PROFIT_PCT=0.25
STOP_LOSS_PCT=0.20
# Fraction of a position sold on the first take-profit tier (fires once).
PARTIAL_TP_SELL_PCT=0.75
MIN_EDGE=0.08
MIN_CLAUDE_SCORE=7
MAX_OPEN_POSITIONS=8
WHALE_MIN_PNL=10000
# Min profit margin (pnl/volume) to qualify a whale — NOT a win rate.
WHALE_MIN_PNL_MARGIN=0.05
# Absolute PnL that admits a whale even on a thin margin (big winners kept).
WHALE_BIG_PNL_OVERRIDE=50000
# Recency filter: drop whales with negative PnL over the trailing N days.
WHALE_RECENCY_DAYS=90
WHALE_RECENCY_CACHE_SECONDS=21600
WHALE_RECENCY_FETCH_LIMIT=200
COPY_MAX_DELAY_SECONDS=300
SCAN_INTERVAL_SECONDS=30
POSITION_CHECK_SECONDS=600

# ── Multi-whale consensus filter ──────────────────────────────
CONSENSUS_MIN_WHALES=3
CONSENSUS_WINDOW_HOURS=4

# ── Enhanced risk engine ──────────────────────────────────────
DRAWDOWN_BREAKER_PCT=0.15
PEAK_BANKROLL=50.0
MAX_SAME_DAY_RESOLUTIONS=3
MAX_YES_CONCENTRATION=0.60

# ── Committee model cascade ───────────────────────────────────
# Cheapest tier that does the job. Override per-agent ids if Virtuals rejects one.
MODEL_OPUS=claude-opus-4-5
MODEL_SONNET=claude-sonnet-4-6
MODEL_HAIKU=claude-haiku-4-5
# Per-agent overrides (optional): MODEL_WHALE_INTENT, MODEL_EFFICIENCY,
# MODEL_ARCHETYPE, MODEL_CRO, MODEL_PORTFOLIO, MODEL_SIZING, MODEL_COMMITTEE
COMMITTEE_PARALLEL=true

# ── Real-time feed ────────────────────────────────────────────
USE_WEBSOCKET=false
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
WHALE_REFRESH_SECONDS=300

# ── Probability calibration ───────────────────────────────────
CALIBRATION_ENABLED=true
CALIBRATION_MIN_SAMPLES=20
MAX_PROB_DEVIATION=0.15
# Tighter edge cap applied until CALIBRATION_MIN_SAMPLES outcomes exist (cold start).
COLD_START_MAX_DEVIATION=0.05

# ── Backtest / execution realism ──────────────────────────────
SLIPPAGE_BPS=150
FILL_SPREAD_BPS=100
