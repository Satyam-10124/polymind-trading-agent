# Base URL the dashboard uses for API calls.
# Dev: leave unset — vite.config.ts proxies /api to http://localhost:8000.
# Prod: set to the API's absolute base when the dashboard is served from a
# different origin than the backend, e.g.
#   VITE_API_BASE=https://api.your-domain.com/api
VITE_API_BASE=/api
